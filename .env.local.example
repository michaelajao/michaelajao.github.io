# Formspree Configuration
# https://formspree.io/
# 1. Create a free account and a new form.
# 2. Copy the form ID from your form's dashboard — it's the short string
#    at the end of the endpoint URL (e.g. https://formspree.io/f/xxxxxxxx → xxxxxxxx).
# 3. Paste it below.
#
# Note: Formspree form IDs are public identifiers (not secrets). Keeping them in
# an env var just makes it easy to swap between forms per environment or fork.

NEXT_PUBLIC_FORMSPREE_FORM_ID=your-form-id-here

# Instructions:
# 1. Copy this file to .env.local
# 2. Replace the placeholder with your actual Formspree form ID
# 3. Ensure .env.local is in your .gitignore (it is by default)
#
# For the deployed site, set the same variable as a GitHub Actions secret
# named NEXT_PUBLIC_FORMSPREE_FORM_ID in the repository settings.
